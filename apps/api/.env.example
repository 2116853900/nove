# Copy to apps/api/.env (never commit real secrets)

APP_ENV=development
# production requires API_KEY, ENCRYPTION_KEY, SECRET_KEY

API_KEY=
ENCRYPTION_KEY=
SECRET_KEY=

# SQLite by default; use Postgres for production-style runs
# DATABASE_URL=postgresql+psycopg://nove:CHANGE_ME@localhost:5432/nove
# DATABASE_URL=sqlite:///./data/nove.db

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
MAX_CONCURRENT_JOBS=2
ENABLE_PGVECTOR=1

# Optional vector store (Docker compose sets these)
# QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION_PREFIX=nove_memory

# Hugging Face mirror for local embeddings (optional)
# EMBEDDING_HF_ENDPOINT=https://hf-mirror.com
