                                      "content": "已锁定 · 用户手写",
                                      "fontFamily": "$font-ui",
                                      "fontSize": 11,
                                      "fontWeight": "normal"
                                    }
                                  ]
                                },
                                {
                                  "type": "text",
                                  "id": "lNm18",
                                  "name": "锁定段落正文",
                                  "fill": "$text-primary",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "「会。」林舟终于开口。他从怀里取出那张被反复折叠的羊皮纸，指尖在边缘停顿了一下，「如果他还记得十年前的约定。」",
                                  "lineHeight": 1.78,
                                  "fontFamily": "$font-body",
                                  "fontSize": 18,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "Ktuof",
                          "name": "审计标记段落",
                          "width": "fill_container",
                          "gap": 8,
                          "children": [
                            {
                              "type": "frame",
                              "id": "pQAxM",
