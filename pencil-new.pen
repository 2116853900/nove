                            {
                              "type": "frame",
                              "id": "acYq9",
                              "name": "锁定内容",
                              "width": "fill_container",
                              "layout": "vertical",
                              "gap": 6,
                              "children": [
                                {
                                  "type": "frame",
                                  "id": "xhVR5",
                                  "name": "锁定标签行",
                                  "gap": 4,
                                  "alignItems": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "id": "oOcEt",
                                      "name": "锁图标",
                                      "width": 12,
                                      "height": 12,
                                      "icon": "lock",
                                      "library": "lucide",
                                      "fill": "$info"
