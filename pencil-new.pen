                            {
                              "type": "frame",
                              "id": "Xs7MW",
                              "name": "审计内容",
                              "width": "fill_container",
                              "layout": "vertical",
                              "gap": 6,
                              "children": [
                                {
                                  "type": "frame",
                                  "id": "NvcHH",
                                  "name": "审计标签行",
                                  "gap": 4,
